# ─────────────────────────────────────────────
# Inventory Management App – Environment Template
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────

# App
APP_ENV=development           # development | staging | production
APP_VERSION=1.0.0

# Storage
STORAGE_KEY_PREFIX=inv_app_   # Prefix for all AsyncStorage keys

# Feature Flags
ENABLE_QR_SCAN=true
ENABLE_BARCODE_SCAN=true
